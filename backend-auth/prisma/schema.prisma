datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  scans     Scan[]  
}


model Scan {
  id        Int      @id @default(autoincrement())
  text      String
  aiScore   Float
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}
